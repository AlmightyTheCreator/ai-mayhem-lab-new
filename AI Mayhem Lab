}

function updateRoom() {
  const id = $('roomSelect').value || 'dungeon';
  $('room').className = `room ${rooms[id].className}`;
  $('roomTitle').textContent = rooms[id].name;
}
function updateCharacter() {
  const gender = $('aiGender').value.toLowerCase();
