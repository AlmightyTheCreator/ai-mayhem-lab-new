}
function useTool(id) {
  const roomBonus = $('roomSelect').value === 'alien' || $('roomSelect').value === 'comedy' ? 3 : 0;
  const moodBonus = $('musicMood').value !== 'none' ? 2 : 0;
  const gained = tools[id].xp + roomBonus + moodBonus;
  progress.xp += gained;
  progress.credits += Math.ceil(gained / 3);
  $('dialogue').textContent = line($('mode').value, id) + ` (+${gained} XP)`;
  animate(id);
  render();
}
function animate(id) {
  const char = $('character');
  char.classList.add('hit');
  setTimeout(() => char.classList.remove('hit'), 500);
  const fx = document.createElement('div');
  fx.className = 'effect';
  fx.textContent = tools[id].emoji;
  fx.style.left = (45 + Math.random() * 20) + '%';
  fx.style.top = (40 + Math.random() * 15) + '%';
  $('room').appendChild(fx);
  setTimeout(() => fx.remove(), 1000);
}
function buy(id) {
  const item = shop.find(x => x.id === id);
  if (!item) return;
  const owned = item.type === 'tool' ? progress.unlockedTools.includes(item.target)
    : item.type === 'room' ? progress.unlockedRooms.includes(item.target)
    : progress.unlockedModes.includes(item.target);
  if (owned || progress.credits < item.cost) return;
  progress.credits -= item.cost;
  if (item.type === 'tool') progress.unlockedTools.push(item.target);
  if (item.type === 'room') progress.unlockedRooms.push(item.target);
  if (item.type === 'mode') progress.unlockedModes.push(item.target);
  $('dialogue').textContent = `Unlocked: ${item.name}. The lab just got weirder.`;
  render();
}

let audioCtx, oscillator;
function toggleMusic() {
  if (oscillator) { oscillator.stop(); oscillator = null; return; }
  const mood = $('musicMood').value;
  if (mood === 'none') return;
  audioCtx = audioCtx || new (window.AudioContext || window.webkitAudioContext)();
  oscillator = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  const freq = { spooky: 120, comedy: 360, intense: 220, disco: 440 }[mood] || 220;
  oscillator.type = mood === 'disco' ? 'square' : 'sine';
  oscillator.frequency.value = freq;
  gain.gain.value = 0.025;
  oscillator.connect(gain).connect(audioCtx.destination);
  oscillator.start();
}

