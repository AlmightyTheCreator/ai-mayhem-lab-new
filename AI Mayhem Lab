  const current = roomSelect.value || progress.unlockedRooms[0];
  roomSelect.innerHTML = progress.unlockedRooms.map(id => `<option value="${id}">${rooms[id].name}</option>`).join('');
  roomSelect.value = progress.unlockedRooms.includes(current) ? current : progress.unlockedRooms[0];
  updateRoom();

  $('toolGrid').innerHTML = progress.unlockedTools.map(id => `
