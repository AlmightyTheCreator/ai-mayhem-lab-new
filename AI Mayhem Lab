      <p>${tools[id].desc}</p>
      <button onclick="useTool('${id}')">Use</button>
    </div>`).join('');

  $('shopGrid').innerHTML = shop.map(item => {
    const owned = item.type === 'tool' ? progress.unlockedTools.includes(item.target)
      : item.type === 'room' ? progress.unlockedRooms.includes(item.target)
      : progress.unlockedModes.includes(item.target);
    const canBuy = progress.credits >= item.cost && !owned;
    return `<div class="card"><h4>${item.name}</h4><p>${owned ? 'Unlocked' : item.cost + ' credits'}</p><button class="${canBuy ? '' : 'locked'}" onclick="buy('${item.id}')">${owned ? 'Owned' : 'Buy'}</button></div>`;
